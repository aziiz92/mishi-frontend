{
  admin off
  auto_https off
}

:8080 {
  encode zstd gzip

  handle /healthz {
    respond "ok" 200
  }

  handle {
    root * /srv
    try_files {path} /index.html

    header {
      -Server
      X-Content-Type-Options "nosniff"
      X-Frame-Options "DENY"
      Referrer-Policy "strict-origin-when-cross-origin"
    }

    file_server
  }

  log {
    output stdout
    format console
  }
}

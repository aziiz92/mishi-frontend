{
  admin off
  auto_https off
}

:8080 {
  encode zstd gzip

  @shared path /s /s/*
  header @shared X-Robots-Tag "noindex, nofollow, noarchive"

  handle /healthz {
    respond "ok" 200
  }

  handle {
    root * /srv
    try_files {path} /index.html

    header {
      -Server
      X-Content-Type-Options "nosniff"
      X-Frame-Options "DENY"
      Referrer-Policy "strict-origin"
    }

    file_server
  }

  log {
    output stdout
    format console
  }
}
